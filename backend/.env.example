# Copy to backend/.env before running backend/docker-compose.yml
# cp .env.example .env

# Use hostname "postgres" when running via Docker Compose (internal network)
DB_URL=jdbc:postgresql://postgres:5432/taskflow
DB_USERNAME=taskflow
DB_PASSWORD=change-me-to-a-strong-password

JWT_SECRET=change-this-to-a-secure-256-bit-secret-key-in-production
JWT_EXPIRATION_MS=86400000

# Comma-separated allowed frontend origins (external port 3003)
CORS_ALLOWED_ORIGINS=http://localhost:3003

# Default admin user (created on startup if missing — see DataSeeder)
ADMIN_PASSWORD=change-me-to-a-strong-admin-password

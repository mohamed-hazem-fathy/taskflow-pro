# Copy to .env in the repository root before running docker-compose.prod.yml
# cp .env.example .env

# PostgreSQL (internal Docker network only — not exposed to host)
DB_NAME=taskflow
DB_USERNAME=taskflow
DB_PASSWORD=change-me-to-a-strong-password

# JWT
JWT_SECRET=change-this-to-a-secure-256-bit-secret-key-in-production
JWT_EXPIRATION_MS=86400000

# Backend CORS — comma-separated list of allowed frontend origins
# Add your domain when using nginx: https://taskflow.yourdomain.com
CORS_ALLOWED_ORIGINS=http://localhost:3003

# Frontend — must match the host-accessible backend URL (external port 8081)
NEXT_PUBLIC_API_URL=http://localhost:8081

# Default admin user (created on startup if missing — see backend DataSeeder)
ADMIN_PASSWORD=change-me-to-a-strong-admin-password
